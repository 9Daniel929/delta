UnlockSection:NewButton("Unlock All Skins", "Local-side only skin access", function()
    -- Logic for local skin spoofing
    print("Skins Unlocked (Visual)")
end)

UnlockSection:NewButton("Unlock All Weapons", "Access restricted loadouts", function()
    print("Weapons Unlocked (Visual)")
