-- Rivals Premium Executor Script
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com"))()
local Window = Library.CreateLib("Rivals Premium Executor", "BloodTheme")

-- COMBAT TAB (Aimbot)
local Combat = Window:NewTab("Combat")
local CombatSection = Combat:NewSection("Aimbot")

CombatSection:NewButton("Enable Silent Aim", "Locks onto players automatically", function()
    -- Universal Aimbot Module
    loadstring(game:HttpGet("https://raw.githubusercontent.com/Exunys/Aimbot-V3/main/src/Aimbot.lua"))()()
    print("Aimbot V3 Loaded")
end)

-- UNLOCKS TAB (Skins & Weapons)
