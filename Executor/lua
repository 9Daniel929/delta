-- VISUALS TAB (Sky Settings)
local Visuals = Window:NewTab("Visuals")
local SkySection = Visuals:NewSection("Sky Effects")

SkySection:NewButton("Stretch Sky", "Gray sky effect for high FPS", function()
    -- Uses standard "Gray Sky" fast flag logic
    local sky = Instance.new("Sky")
    sky.SkyboxBk = "rbxassetid://6073763717"
    sky.Parent = game.Lighting
    print("Sky Stretched")
end)

SkySection:NewButton("Better Sky", "HD Skybox replacement", function()
    -- Replaces default textures with high-res space skybox
    local Sky = game.Lighting:FindFirstChild("Sky") or Instance.new("Sky", game.Lighting)
    Sky.SkyboxBk = "rbxassetid://10128060"
    print("HD Sky Applied")
end)

